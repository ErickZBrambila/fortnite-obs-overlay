# Fortnite API key from https://fortnite-api.com
# See README.md for instructions on how to obtain your API key
FORTNITE_API_KEY=your_api_key_here

# Optional: pre-load a player on server start
DEFAULT_USERNAME=

# Server port (default: 3000)
PORT=3000

# How often to poll the Fortnite API in milliseconds (default: 30 seconds)
# Avoid setting this below 15000 to respect API rate limits
POLL_INTERVAL_MS=30000

# Optional: path to FortniteGame.log for real-time kill/match detection
# Leave blank to disable log polling.
#
# Windows (replace YourName with your Windows username):
# FORTNITE_LOG_PATH=C:\Users\YourName\AppData\Local\FortniteGame\Saved\Logs\FortniteGame.log
#
# macOS (if running via CrossOver):
# FORTNITE_LOG_PATH=/Users/YourName/Library/Application Support/CrossOver/Bottles/Fortnite/drive_c/users/YourName/AppData/Local/FortniteGame/Saved/Logs/FortniteGame.log
FORTNITE_LOG_PATH=
