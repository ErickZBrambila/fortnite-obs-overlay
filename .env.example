# Fortnite API key from https://fortnite-api.com
# See README.md for instructions on how to obtain your API key
FORTNITE_API_KEY=your_api_key_here

# Optional: pre-load a player on server start
DEFAULT_USERNAME=

# Server port (default: 3000)
PORT=3000

# How often to poll the Fortnite API in milliseconds (default: 30 seconds)
# Avoid setting this below 15000 to respect API rate limits
POLL_INTERVAL_MS=30000
